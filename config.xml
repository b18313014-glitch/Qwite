<?xml version='1.0' encoding='utf-8'?>
<widget id="org.qwit.terminal" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Qwit Terminal</name>
    <description>Автономный терминал Qwit с поддержкой NFC и Яндекс ID</description>
    <author email="support@qwit.org" href="https://www.terminal-qwit.duckdns.org">Team Qwit</author>
    
    <content src="index.html" />
    
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-navigation href="https://*.supabase.co" />
    <allow-navigation href="https://oauth.yandex.ru" />

    <plugin name="phonegap-nfc" spec="~5.0.0" />
    
    <preference name="Fullscreen" value="true" />
    <preference name="Orientation" value="landscape" />
</widget>
